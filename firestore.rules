rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: siteContent
    // Fields:
    //   - key: string (required) - unique identifier
    //   - value: string (required) - text or image URL
    //   - updatedAt: timestamp (optional)
    //
    // Collection: news
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - image: string (optional)
    //   - date: timestamp (required)
    //   - category: string (optional)
    //   - author: string (optional)
    //
    // Collection: gallery
    // Fields:
    //   - title: string (required)
    //   - src: string (required)
    //   - category: string (required)
    //   - createdAt: timestamp (optional)
    //
    // Collection: testimonials
    // Fields:
    //   - quote: string (required)
    //   - author: string (required)
    //   - role: string (required)
    //   - image: string (optional)
    //
    // Collection: institutionalPrograms
    // Fields:
    //   - title: string (required)
    //   - category: string (required)
    //   - duration: string (optional)
    //   - image: string (optional)
    //   - goal: string (optional)
    //
    // Collection: documentCategories
    // Fields:
    //   - name: string (required)
    //
    // Collection: documents
    // Fields:
    //   - title: string (required)
    //   - url: string (required)
    //   - categoryId: string (required) - reference to documentCategories
    //   - createdAt: string (required)
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required) - ['admin', 'editor', 'user']
    //   - displayName: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "narcis@bpt.ba" && request.auth.token.email_verified == true));
    }

    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /institutionalPrograms/{programId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /documents/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /documentCategories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
